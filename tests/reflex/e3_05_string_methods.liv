fn main():
    print("ababa".count("a"))
    print("hello world".rfind("o"))
    print("a\nb\nc".splitlines())
    print("hello world".title())
    print("hello".capitalize())
    print("5".zfill(3))
    print("hi".ljust(5, "-"))
    print("hi".rjust(5, "-"))
    print("hi".center(6, "-"))
    print("key=value".partition("="))
    print("prefix_body".removeprefix("prefix_"))
    print("body_suffix".removesuffix("_suffix"))
    print("123".isdigit())
    print("abc".isalpha())
    print("   ".isspace())
    print("ABC".isupper())
    print("abc".islower())
