{
  "name": "olive-lang",
  "displayName": "Olive",
  "description": "Language support for Olive: diagnostics as you type, hover, go-to-definition, completion, and formatting via pit lsp.",
  "version": "0.1.0",
  "publisher": "olive-lang",
  "license": "Apache-2.0",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:olive"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "olive",
        "aliases": [
          "Olive"
        ],
        "extensions": [
          ".liv"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "configuration": {
      "title": "Olive",
      "properties": {
        "olive.serverPath": {
          "type": "string",
          "default": "pit",
          "description": "Path to the pit executable used to launch the language server (`pit lsp`) and the debug adapter (`pit dap`)."
        }
      }
    },
    "breakpoints": [
      {
        "language": "olive"
      }
    ],
    "debuggers": [
      {
        "type": "olive",
        "label": "Olive",
        "languages": [
          "olive"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "Path to the .liv file to run.",
                "default": "${file}"
              },
              "stopOnEntry": {
                "type": "boolean",
                "description": "Stop before the first statement of main.",
                "default": false
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "olive",
            "request": "launch",
            "name": "Run current file",
            "program": "${file}",
            "stopOnEntry": false
          }
        ],
        "configurationSnippets": [
          {
            "label": "Olive: Launch current file",
            "description": "Run and debug the file open in the editor.",
            "body": {
              "type": "olive",
              "request": "launch",
              "name": "Run current file",
              "program": "^\"\\${file}\"",
              "stopOnEntry": false
            }
          }
        ]
      }
    ]
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
